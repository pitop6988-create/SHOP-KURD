rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    // Only basic checking for now since there isn't a complex admin setup
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn(); // In real app, only Admins
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn(); // In real app, separate users (can update own) vs admins
      allow delete: if false;
    }
  }
}
