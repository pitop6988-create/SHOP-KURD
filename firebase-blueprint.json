{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "price", "currency", "imageUrl"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
              "items": { "$ref": "#/entities/CartItem" }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivered", "cancelled"] },
        "date": { "type": "string" }
      },
      "required": ["customerName", "userId", "items", "total", "status", "date"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "Item in cart",
      "type": "object",
      "properties": {
        "product": { "$ref": "#/entities/Product" },
        "quantity": { "type": "number" }
      },
      "required": ["product", "quantity"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Publicly readable products"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders placed by users"
    },
    "/promo_codes/{codeId}": {
      "schema": {
        "title": "PromoCode",
        "description": "Promo codes for discounts",
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "value": { "type": "string" }
        },
        "required": ["code", "value"]
      },
      "description": "Promo codes available"
    }
  }
}
